<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_post_card"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_avatar_box"
            android:padding="10dp">

            <ImageView
                android:id="@+id/image_post_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@string/avatar_placeholder"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_post_author"
                style="@style/SketchPostMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alice" />

            <TextView
                android:id="@+id/text_post_date"
                style="@style/SketchLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="26/03/2026" />
        </LinearLayout>

        <TextView
            android:id="@+id/button_delete_post"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_field"
            android:contentDescription="@string/delete_post_title"
            android:fontFamily="monospace"
            android:gravity="center"
            android:text="@string/delete_mark"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_post_content"
        style="@style/SketchPostBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="This is test content." />
</LinearLayout>
