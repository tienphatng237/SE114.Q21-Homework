<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingTop="18dp"
    android:paddingBottom="18dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="@dimen/auth_panel_width"
                android:layout_height="@dimen/auth_panel_height"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_panel"
                android:orientation="vertical"
                android:paddingHorizontal="22dp"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_profile_title"
                        style="@style/SketchTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Alice!" />

                    <FrameLayout
                        android:id="@+id/frame_avatar_picker"
                        android:layout_width="86dp"
                        android:layout_height="72dp"
                        android:background="@drawable/bg_avatar_box"
                        android:padding="12dp">

                        <ImageView
                            android:id="@+id/image_avatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/avatar_placeholder"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_gallery" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    style="@style/SketchLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/name_label" />

                <EditText
                    android:id="@+id/edit_name"
                    style="@style/SketchInput"
                    android:hint="@string/hint_name"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName"
                    android:maxLines="1" />

                <TextView
                    style="@style/SketchLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/email_label" />

                <EditText
                    android:id="@+id/edit_email"
                    style="@style/SketchInput"
                    android:hint="@string/hint_email"
                    android:imeOptions="actionNext"
                    android:inputType="textEmailAddress"
                    android:maxLines="1" />

                <TextView
                    style="@style/SketchLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/address_label" />

                <EditText
                    android:id="@+id/edit_address"
                    style="@style/SketchInput"
                    android:hint="@string/hint_address"
                    android:imeOptions="actionNext"
                    android:inputType="textPostalAddress"
                    android:maxLines="1" />

                <TextView
                    style="@style/SketchLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/avatar_image_label" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_choose_image"
                        style="@style/SketchPrimaryButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_image" />

                    <TextView
                        android:id="@+id/text_avatar_status"
                        style="@style/SketchLink"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/no_image_selected" />
                </LinearLayout>

                <TextView
                    style="@style/SketchLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/description_label" />

                <EditText
                    android:id="@+id/edit_description"
                    android:layout_width="match_parent"
                    android:layout_height="132dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_field"
                    android:fontFamily="monospace"
                    android:gravity="top|start"
                    android:hint="@string/hint_description"
                    android:inputType="textMultiLine|textCapSentences"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/hint_text"
                    android:textSize="18sp" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_save"
                        style="@style/SketchPrimaryButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="@string/save" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_logout"
                        style="@style/SketchPrimaryButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/logout" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/view_bottom_nav" />
</LinearLayout>
