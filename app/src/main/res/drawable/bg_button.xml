<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/glass_button_fill_pressed"
                android:startColor="@color/primary_blue_dark" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_button_stroke" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/primary_blue_light"
                android:startColor="@color/glass_button_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_button_stroke" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
