<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/surface_soft"
                android:startColor="@color/surface" />
            <stroke
                android:width="1.5dp"
                android:color="@color/outline_soft" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/surface"
                android:startColor="@color/panel_background" />
            <stroke
                android:width="1.5dp"
                android:color="@color/outline" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</selector>
