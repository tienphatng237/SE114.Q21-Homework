<resources>
    <style name="SketchTitle">
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="SketchHeroTitle">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="SketchHeroSubtitle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#DCEAFF</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="SketchLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="SketchInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_field</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/hint_text</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="SketchButton">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">112dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingHorizontal">18dp</item>
        <item name="android:paddingVertical">10dp</item>
    </style>

    <style name="SketchPrimaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">112dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingHorizontal">18dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="backgroundTint">@color/glass_button_fill</item>
        <item name="strokeColor">@color/glass_button_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="rippleColor">#80FFFFFF</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="SketchMenuButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">42dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary_blue_dark</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="backgroundTint">@color/glass_chip_fill</item>
        <item name="strokeColor">@color/glass_chip_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="rippleColor">#80FFFFFF</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="SketchLink">
        <item name="android:textColor">@color/primary_blue_dark</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="SketchNavLabel">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SketchPostMeta">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SketchPostBody">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>
</resources>
